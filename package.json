    "idb": "^8.0.1",
    "postcss": "8.5.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.4.0",
    "react-router-dom": "^6.28.2",
    "tailwindcss": "^3.4.17",
    "zustand": "^5.0.3"
